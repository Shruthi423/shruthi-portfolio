# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets stay local, but .env.example is committed so
# anyone cloning the repo (or future-me) sees which vars exist
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local font / asset sources — only the curated copies in public/ are tracked
/Fonts/
.DS_Store

# Original-source assets — only the processed copies in public/ are tracked
/my_pic.jpeg
/About_images/
/Handmade_homestead_images/
/Fleed_images/
/Ghost_images/
/Kodif_assets/
/MSI_expo_images/
/Onki_images/
/Theta_assets/
/Zuge_images/

# Rejected day/night reference images (never used)
/Moon.png
/Sun.png

# Local raw source images, not served by the site
Spothive_images/
